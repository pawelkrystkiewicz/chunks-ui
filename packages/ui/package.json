{
  "name": "chunks-ui",
  "version": "0.1.2",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme.css": "./dist/theme.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:visual:update": "vitest run --config vitest.visual.config.ts --update",
    "lint": "biome check .",
    "check-types": "tsc --noEmit && tsc --noEmit --project tsconfig.visual.json",
    "clean": "rm -rf .turbo node_modules dist coverage"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "motion": ""
  },
  "peerDependenciesMeta": {
    "motion": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@chunks-ui/typescript-config": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "motion": "^12.38.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pawelkrystkiewicz/chunks-ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/pawelkrystkiewicz/chunks-ui/issues"
  },
  "homepage": "https://github.com/pawelkrystkiewicz/chunks-ui#readme",
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "tailwind-css",
    "base-ui",
    "headless",
    "motion",
    "animation",
    "accessible",
    "typescript",
    "react-19"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
