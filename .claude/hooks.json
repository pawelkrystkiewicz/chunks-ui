{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Constraints: bun (not npm/yarn/pnpm). Variants in *.Variants.ts files. Base UI render prop (not asChild). Commits: type(scope): message. No git push — human reviews first.'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== CLAUDE.md (re-injected before compaction) ===' && cat CLAUDE.md"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "git log -1 --format=tformat:'[%ci] %D | %h %s' >> .claude/output/session-log.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "block",
            "message": "Agents must not push to remote. A human must review and push."
          }
        ]
      },
      {
        "matcher": "Bash(git reset --hard*)",
        "hooks": [
          {
            "type": "block",
            "message": "Hard reset is not allowed by agents. Use safer alternatives."
          }
        ]
      },
      {
        "matcher": "Bash(git push --force*)",
        "hooks": [
          {
            "type": "block",
            "message": "Force push is never allowed by agents."
          }
        ]
      },
      {
        "matcher": "Write(.github/**)",
        "hooks": [
          {
            "type": "block",
            "message": "Agents must not modify CI/CD workflows. A human must make these changes."
          }
        ]
      },
      {
        "matcher": "Edit(.github/**)",
        "hooks": [
          {
            "type": "block",
            "message": "Agents must not modify CI/CD workflows. A human must make these changes."
          }
        ]
      },
      {
        "matcher": "Write(CLAUDE.md)",
        "hooks": [
          {
            "type": "block",
            "message": "CLAUDE.md is a human-authored spec. Agents must not overwrite it."
          }
        ]
      },
      {
        "matcher": "Edit(CLAUDE.md)",
        "hooks": [
          {
            "type": "block",
            "message": "CLAUDE.md is a human-authored spec. Agents must not modify it."
          }
        ]
      },
      {
        "matcher": "Write(PRD.md)",
        "hooks": [
          {
            "type": "block",
            "message": "PRD.md is a human-authored spec. Agents must not overwrite it."
          }
        ]
      },
      {
        "matcher": "Edit(PRD.md)",
        "hooks": [
          {
            "type": "block",
            "message": "PRD.md is a human-authored spec. Agents must not modify it."
          }
        ]
      },
      {
        "matcher": "Write(.claude/hooks.json)",
        "hooks": [
          {
            "type": "block",
            "message": "Agents must not modify safety hooks. A human must manage hooks.json."
          }
        ]
      },
      {
        "matcher": "Edit(.claude/hooks.json)",
        "hooks": [
          {
            "type": "block",
            "message": "Agents must not modify safety hooks. A human must manage hooks.json."
          }
        ]
      }
    ]
  }
}
