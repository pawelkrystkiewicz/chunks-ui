{
  "name": "chunks-ui-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "test:unit:coverage": "turbo run test:unit:coverage",
    "format": "biome format --write .",
    "lint:root": "biome check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=chunks-ui && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.27.1",
    "lefthook": "^2.1.3",
    "turbo": "^2.6.1"
  },
  "packageManager": "bun@1.2.10",
  "peerDependencies": {
    "typescript": "^5"
  }
}
